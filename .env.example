# Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Google Site Verification
NEXT_PUBLIC_GOOGLE_VERIFY=your-google-verification-token

# API Configuration
NEXT_PUBLIC_API_TIMEOUT=8000
NEXT_PUBLIC_RSS_FEEDS_CACHE_TIME=900000

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_SUMMARIES=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SHARING=true

# Error Tracking (optional - set to enable)
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
